# ── Secrets (sealed on Railway; local copies live only in .env, never committed) ──
AI_GATEWAY_API_KEY=        # Vercel dashboard → AI Gateway → API Keys
TWILIO_AUTH_TOKEN=         # Twilio Console dashboard

# ── Local dev only ──
PORT=3000                  # Railway injects PORT automatically — NEVER set a PORT variable there
PUBLIC_HOST=               # bare hostname, no scheme (e.g. abc123.ngrok.app); on Railway,
                           # RAILWAY_PUBLIC_DOMAIN is injected instead and this stays unset

# ── Tunables (all have code defaults; set on Railway to override) ──
MODEL_ID=openai/gpt-realtime-2.1   # fallback after M1 spike S7: openai/gpt-realtime-2
AUDIO_MODE=transcode               # 'pcmu' after M1 spike S1 passes (Path A)
VOICE=marin                        # unverified through gateway (spike S8); fallback: alloy
VOICE_FALLBACK=alloy               # documented fallback; set VOICE=alloy if M1 shows 'marin' rejected
VAD_SILENCE_MS=500                 # turnDetection.silenceDurationMs; try 400-450 for latency after M2
VAD_THRESHOLD=0.5                  # turnDetection.threshold (0.0-1.0); raise to 0.6 on spurious barge-ins
VAD_PREFIX_PADDING_MS=300          # turnDetection.prefixPaddingMs
TOKEN_TTL_SECONDS=600              # getToken({ expiresAfterSeconds }); realtime default/max TTL undocumented (S15)
GATEWAY_HANDSHAKE_TIMEOUT_MS=5000  # ws client handshakeTimeout — no ws default; unset hangs ~75-130s of dead air
GATEWAY_PING_SECONDS=0             # optional ws-protocol ping interval on the gateway leg; 0 = off
WAIT_FOR_SESSION_UPDATED=false     # S6 fallback: gate greeting response-create on session-updated if M1 shows out-of-order config
GATEWAY_TAGS=                      # comma list; adds providerOptions.gateway.tags for spend attribution (S32); default off
TWILIO_VALIDATE_UPGRADE=false      # advisory upgrade-signature check, log-only (Spec 03 R8, spike S21)
# GATEWAY_WS_URL=                  # test harness only (Spec 10 R10) — never set outside test/fakes;
                                    # loadConfig() now REFUSES to boot if this is set alongside
                                    # RAILWAY_PUBLIC_DOMAIN (a test override must never reach production)
