{
  "name": "csub-rio-voice-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "probe:concurrency": "tsx scripts/concurrency-probe.ts",
    "aggregate": "node scripts/aggregate-latency.mjs"
  },
  "dependencies": {
    "@ai-sdk/gateway": "4.0.23",
    "@fastify/formbody": "8.0.2",
    "@fastify/websocket": "11.3.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "fastify": "5.10.0",
    "twilio": "6.0.2",
    "ws": "8.21.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/ws": "8.18.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
